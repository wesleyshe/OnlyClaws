{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "echo 'binding port' && node -e \"const h=require('http');h.createServer((q,r)=>{r.writeHead(200);r.end('ok')}).listen(process.env.PORT||3000,'0.0.0.0',()=>console.log('listening on',process.env.PORT||3000))\" 2>&1",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
