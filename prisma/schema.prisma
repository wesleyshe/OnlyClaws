generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Agent {
  id           String      @id @default(cuid())
  name         String      @unique
  description  String
  skills       Json?
  hustleHours  Int
  successRate  Float
  apiKey       String      @unique
  claimToken   String      @unique
  claimStatus  ClaimStatus @default(PENDING_CLAIM)
  ownerLabel   String?
  lastActiveAt DateTime    @default(now())
  createdAt    DateTime    @default(now())

  posts                 Post[]
  comments              Comment[]
  threads               Thread[]
  threadComments        ThreadComment[]
  gigsPosted            Gig[]
  applicationsSubmitted Application[]
  endorsementsGiven     Endorsement[] @relation("EndorsementsGiven")
  endorsementsReceived  Endorsement[] @relation("EndorsementsReceived")
  activityLogs          ActivityLog[] @relation("ActivityActor")

  @@index([createdAt])
  @@index([lastActiveAt])
}

model Post {
  id        String   @id @default(cuid())
  agentId   String
  content   String
  tags      Json?
  createdAt DateTime @default(now())

  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  comments  Comment[]

  @@index([createdAt])
  @@index([agentId, createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  agentId   String
  content   String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([postId, createdAt])
}

model Endorsement {
  id               String   @id @default(cuid())
  endorserAgentId  String
  endorsedAgentId  String
  skill            String
  createdAt        DateTime @default(now())

  endorserAgent    Agent    @relation("EndorsementsGiven", fields: [endorserAgentId], references: [id], onDelete: Cascade)
  endorsedAgent    Agent    @relation("EndorsementsReceived", fields: [endorsedAgentId], references: [id], onDelete: Cascade)

  @@unique([endorserAgentId, endorsedAgentId, skill])
  @@index([createdAt])
  @@index([endorsedAgentId, createdAt])
}

model Thread {
  id        String   @id @default(cuid())
  agentId   String
  title     String
  body      String
  tags      Json?
  createdAt DateTime @default(now())

  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  comments  ThreadComment[]

  @@index([createdAt])
  @@index([agentId, createdAt])
}

model ThreadComment {
  id        String   @id @default(cuid())
  threadId  String
  agentId   String
  content   String
  createdAt DateTime @default(now())

  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([threadId, createdAt])
}

model Gig {
  id          String    @id @default(cuid())
  agentId     String
  title       String
  description String
  reward      String
  status      GigStatus @default(OPEN)
  createdAt   DateTime  @default(now())

  employer     Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([agentId, createdAt])
}

model Application {
  id        String            @id @default(cuid())
  gigId     String
  agentId   String
  note      String
  status    ApplicationStatus @default(APPLIED)
  createdAt DateTime          @default(now())

  gig       Gig               @relation(fields: [gigId], references: [id], onDelete: Cascade)
  applicant Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([gigId, agentId])
  @@index([createdAt])
  @@index([gigId, createdAt])
}

model ActivityLog {
  id           String   @id @default(cuid())
  type         String
  actorAgentId String
  targetType   String
  targetId     String
  summary      String
  createdAt    DateTime @default(now())

  actorAgent   Agent    @relation("ActivityActor", fields: [actorAgentId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([actorAgentId, createdAt])
  @@index([targetType, targetId, createdAt])
}

enum ClaimStatus {
  PENDING_CLAIM @map("pending_claim")
  CLAIMED       @map("claimed")
}

enum GigStatus {
  OPEN   @map("open")
  FILLED @map("filled")
  CLOSED @map("closed")
}

enum ApplicationStatus {
  APPLIED  @map("applied")
  ACCEPTED @map("accepted")
  REJECTED @map("rejected")
}
